---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Expense Tracker | Steve Jevon Rahardjo" description="Intelligent Expense Tracking using Google Agent Development Kit">
  <a href="/projects" class="inline-block mb-8 text-xs text-[var(--muted-foreground)] no-underline hover:text-[var(--text)] transition-colors">&larr; Projects</a>
  <article>
    <header class="mb-8">
      <h1 class="text-2xl md:text-3xl font-bold tracking-tight m-0">Expense Tracker</h1>
      <p class="text-sm text-[var(--muted-foreground)] mt-2">Intelligent Expense Tracking using Google Agent Development Kit</p>
    </header>
    <section class="mb-8">
      <h2 class="text-lg font-bold mb-3">Overview</h2>
      <p class="text-sm leading-relaxed text-[var(--muted-foreground)]">An intelligent expense tracking application that leverages Google's Agent Development Kit to automate expense categorization and provide financial insights through natural language interactions.</p>
    </section>
    <section class="mb-8">
      <h2 class="text-lg font-bold mb-3">Features</h2>
      <div class="flex flex-col text-sm text-[var(--muted-foreground)] leading-relaxed">
        {["AI-powered expense classification","Natural Language Queries","OCR receipt processing","Budget tracking","CSV/PDF export","Multi-currency support"].map(f => (
          <div class="py-2 border-b border-[var(--border)] last:border-none">{f}</div>
        ))}
      </div>
    </section>
    <section>
      <h2 class="text-lg font-bold mb-3">Tech Stack</h2>
      <div class="flex flex-wrap gap-2">
        {["Python","Google ADK","AI Agents","SQLite","FastAPI"].map(t => (
          <span class="text-[10px] font-medium px-2.5 py-1 rounded border border-[var(--border)] bg-[var(--bg)] text-[var(--muted-foreground)]">{t}</span>
        ))}
      </div>
    </section>
  </article>
</BaseLayout>
