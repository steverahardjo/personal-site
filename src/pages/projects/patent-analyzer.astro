---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Patent Analyzer | Steve Jevon Rahardjo" description="AI-Powered Patent Document Analysis System using LLMs and RAG.">
  <a href="/projects" class="inline-block mb-8 text-xs text-[var(--muted-foreground)] no-underline hover:text-[var(--text)] transition-colors">&larr; Projects</a>
  <article>
    <header class="mb-8">
      <h1 class="text-2xl md:text-3xl font-bold tracking-tight m-0">Patent Analyzer</h1>
      <p class="text-sm text-[var(--muted-foreground)] mt-2">AI-Powered Patent Document Analysis System</p>
    </header>
    <section class="mb-8">
      <h2 class="text-lg font-bold mb-3">Overview</h2>
      <p class="text-sm leading-relaxed text-[var(--muted-foreground)]">An intelligent platform for analyzing patent documents using advanced NLP and machine learning. Leverages vector databases, semantic search, and LLMs for context-aware responses.</p>
    </section>
    <section class="mb-8">
      <h2 class="text-lg font-bold mb-3">Features</h2>
      <div class="flex flex-col text-sm text-[var(--muted-foreground)] leading-relaxed">
        {["PDF upload & processing","Vector embeddings for semantic search","Q&A chatbot with context","Automatic topic classification","TRIZ innovation principle extraction","Dockerized deployment"].map(f => (
          <div class="py-2 border-b border-[var(--border)] last:border-none">{f}</div>
        ))}
      </div>
    </section>
    <section class="mb-8">
      <h2 class="text-lg font-bold mb-3">Architecture</h2>
      <p class="text-sm leading-relaxed text-[var(--muted-foreground)]">Multi-service: Backend API (FastAPI), Vector Database (Qdrant), LLM Service, React Frontend.</p>
    </section>
    <section>
      <h2 class="text-lg font-bold mb-3">Tech Stack</h2>
      <div class="flex flex-wrap gap-2">
        {["Python","FastAPI","NLP","Vector DB","Docker","React"].map(t => (
          <span class="text-[10px] font-medium px-2.5 py-1 rounded border border-[var(--border)] bg-[var(--bg)] text-[var(--muted-foreground)]">{t}</span>
        ))}
      </div>
    </section>
  </article>
</BaseLayout>
