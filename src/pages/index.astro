---
import BaseLayout from "../layouts/BaseLayout.astro";
import BackgroundGradientAnimationDemo from "../components/background-gradient-animation-demo";
---

<BaseLayout title="sjrah.net" description="Steve Jevon Rahardjo - building software." page="home">
  <section class="mb-12">
    <h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-1">Hi, I'm Steve</h2>
    <p class="text-sm md:text-base leading-relaxed text-[var(--muted-foreground)]">CS graduate from Monash University, focused on backend systems and AI-centric development.</p>
  </section>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-12">
    <div class="flex gap-4 p-5 rounded-2xl border border-[var(--border)] bg-[var(--bg)] transition-all duration-300 hover:border-[var(--accent)]/30 hover:-translate-y-0.5">
      <div class="flex flex-col">
        <span class="text-[10px] font-bold tracking-widest text-[var(--muted-foreground)] uppercase">Role</span>
        <span class="text-sm mt-1">Backend Engineer / Data</span>
      </div>
    </div>
    <div class="flex gap-4 p-5 rounded-2xl border border-[var(--border)] bg-[var(--bg)] transition-all duration-300 hover:border-[var(--accent)]/30 hover:-translate-y-0.5">
      <div class="flex flex-col">
        <span class="text-[10px] font-bold tracking-widest text-[var(--muted-foreground)] uppercase">Location</span>
        <span class="text-sm mt-1">Malaysia</span>
      </div>
    </div>
  </div>

  <section>
    <div class="flex items-center justify-between mb-6">
      <p class="text-[11px] font-bold tracking-[0.3em] text-[var(--muted-foreground)] uppercase opacity-60">Projects</p>
    </div>
    <div class="flex flex-col gap-4">
      <BackgroundGradientAnimationDemo client:load transition:persist />
      <p class="text-xs text-[var(--muted-foreground)] m-0 border-l-4 border-[var(--accent)] pl-3" id="joke"></p>
      <p class="text-xs text-[var(--muted-foreground)] m-0">status: <span class="text-[var(--accent)] font-semibold">sleep deprived</span></p>
    </div>
  </section>
</BaseLayout>
