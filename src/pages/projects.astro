---
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = [
    {
        title: "Patent Analyzer",
        description:
            "Architected a full-stack patent analysis platform leveraging TRIZ40 principles. Engineered a multi-service backend featuring automated USPTO retrieval, LLM-based classification with context injection, and a high-performance RAG chatbot powered by Qdrant and Cohere reranking.",
        tags: ["Python", "Django", "QdrantDB", "RAG"],
        link: "https://github.com/reneeyst23/patent-analyser-fyp",
    },
    {
        title: "GitAegis",
        description:
            "A high-performance Go CLI security engine. Detects exposed secrets using Shannon entropy and Tree-sitter AST parsing. Designed for CI/CD integration with granular TOML configuration and structured JSON reporting.",
        tags: ["Go", "Cobra", "Tree-sitter", "Security"],
        link: "https://github.com/steverahardjo/gitaegis",
        external: true,
    },
    {
        title: "Autonomous Expense Agent",
        description:
            "A multi-agent multimodal system utilizing the Google ADK and Model Context Protocol (MCP). Implements YOLO-based computer vision for receipt processing and complex MongoDB transactional logic for automated financial tracking.",
        tags: ["Python", "MCP", "YOLO", "Google ADK"],
        link: "/projects/expense-tracker",
    },
    {
        title: "Big Data IoT Pipeline",
        description:
            "Built a resilient real-time data ingestion system using Kafka and PySpark. Implemented custom UDFs for anomaly detection across massive IoT sensor streams, backed by a specialized MongoDB warehouse schema.",
        tags: ["PySpark", "Kafka", "MongoDB"],
        link: "https://github.com/steverahardjo/AWAS_traffic_detector",
    },
];
---

<BaseLayout title="Projects | Steve Jevon Rahardjo" page="projects">
    <div class="container page">
        <h1 class="page-title">Selected <span>Works</span></h1>

        <div class="roulette-container">
            <div class="roulette-track">
                {
                    projects.map((project) => (
                        <a href={project.link} class="project-card-link">
                            <article class="project-card">
                                <div class="card-header">
                                    <span class="card-category">
                                        Engineering
                                    </span>
                                    <h2 class="project-title">
                                        {project.title}
                                    </h2>
                                </div>
                                <p class="project-desc">
                                    {project.description}
                                </p>
                                <div class="tags">
                                    {project.tags.map((tag) => (
                                        <span class="tag">{tag}</span>
                                    ))}
                                </div>
                                <span class="view-trigger">
                                    Explore System →
                                </span>
                            </article>
                        </a>
                    ))
                }
                {/* Duplicate for infinite loop effect if desired */}
            </div>
        </div>
    </div>
</BaseLayout>
