---
import GhCalendar from "../components/GhCalendar.tsx";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
    title="sjrah.net/about"
    description="Learn about Steve Jevon Rahardjo - Data Science graduate from Monash University specializing in backend systems, AI/ML, Python, Go, and database technologies."
    page="about"
>
    <div class="container page about-page">
        <h1 class="page-title">
            <span>About</span>
        </h1>

        <section class="about-intro">
            <p>
                I am a Computer Science graduate from
                <strong>Monash University Malaysia</strong>
                focused on backend systems and AI-centric development.
            </p>
            <p>
                I build side projects around <strong>network programming</strong
                >,
                <strong>database optimization</strong>, and practical <strong
                    >LLM</strong
                >
                applications.
            </p>
            <p>
                My goal is to ship scalable products with clean engineering and
                useful AI features.
            </p>
        </section>

        <section class="about-section">
            <h2 class="about-section-title">Skills</h2>
            <div class="about-skill-selector" role="tablist" aria-label="Skill sections">
                <button class="about-skill-tab is-active" type="button" role="tab" aria-selected="true" data-target="languages">Languages</button>
                <button class="about-skill-tab" type="button" role="tab" aria-selected="false" data-target="aiml">AI/ML</button>
                <button class="about-skill-tab" type="button" role="tab" aria-selected="false" data-target="data-tools">Data Tools</button>
                <button class="about-skill-tab" type="button" role="tab" aria-selected="false" data-target="dev-tools">Dev Tools</button>
            </div>

            <div class="about-cloud-panels">
                <article class="about-cloud-panel is-active" data-panel="languages">
                    <p class="about-cloud-sub">Core programming and query languages</p>
                    <div class="about-word-cloud">
                        <span class="about-word">Python</span>
                        <span class="about-word">Java</span>
                        <span class="about-word">Go</span>
                        <span class="about-word">SQL</span>
                        <span class="about-word">R</span>
                        <span class="about-word">TypeScript</span>
                    </div>
                </article>

                <article class="about-cloud-panel" data-panel="aiml" hidden>
                    <p class="about-cloud-sub">Applied model and retrieval workflows</p>
                    <div class="about-word-cloud">
                        <span class="about-word">LLMs</span>
                        <span class="about-word">RAG</span>
                        <span class="about-word">Google ADK</span>
                        <span class="about-word">Hugging Face</span>
                        <span class="about-word">Scikit-Learn</span>
                        <span class="about-word">XGBoost</span>
                    </div>
                </article>

                <article class="about-cloud-panel" data-panel="data-tools" hidden>
                    <p class="about-cloud-sub">Streaming, analytics, and data infrastructure</p>
                    <div class="about-word-cloud">
                        <span class="about-word">PySpark</span>
                        <span class="about-word">Kafka</span>
                        <span class="about-word">MongoDB</span>
                        <span class="about-word">QdrantDB</span>
                        <span class="about-word">Pandas</span>
                        <span class="about-word">Matplotlib</span>
                    </div>
                </article>

                <article class="about-cloud-panel" data-panel="dev-tools" hidden>
                    <p class="about-cloud-sub">Build, automation, and delivery workflow</p>
                    <div class="about-word-cloud">
                        <span class="about-word">Git</span>
                        <span class="about-word">Docker</span>
                        <span class="about-word">GitHub Actions</span>
                        <span class="about-word">Flask</span>
                        <span class="about-word">BeautifulSoup</span>
                    </div>
                </article>
            </div>
        </section>

        <section class="about-section">
            <h2 class="about-section-title">Education</h2>
            <article class="about-card">
                <h3 class="about-card-title">
                    Bachelor of Computer Science (Data Science)
                </h3>
                <p class="about-card-org">Monash University Malaysia</p>
                <p class="about-card-date">Feb 2023 - Nov 2025</p>

                <p class="about-meta-label">Relevant Coursework</p>
                <div class="about-chip-list">
                    <span class="about-chip">Data Science</span>
                    <span class="about-chip">DSA</span>
                    <span class="about-chip">Data Modelling</span>
                    <span class="about-chip">Visualization</span>
                    <span class="about-chip">OOP</span>
                    <span class="about-chip">Warehousing</span>
                    <span class="about-chip">Android Dev</span>
                    <span class="about-chip">Big Data</span>
                </div>
            </article>
        </section>

        <section class="about-section">
            <h2 class="about-section-title">Experience</h2>
            <div class="about-stack">
                <article class="about-card">
                    <h3 class="about-card-title">
                        Data Analyst Trainee (CDP Team)
                    </h3>
                    <p class="about-card-org">SynergyXYZ</p>
                    <p class="about-card-date">Nov 2024 - Feb 2025</p>
                    <p class="about-card-body">
                        Researched Customer Data Platform vendors, formulated
                        CDP service offerings, and compiled technical
                        documentation. Gained experience with Google Ads.
                    </p>
                </article>

                <article class="about-card">
                    <h3 class="about-card-title">Website Admin (Volunteer)</h3>
                    <p class="about-card-org">PPI Monash Malaysia</p>
                    <p class="about-card-date">Jul 2024 - Nov 2025</p>
                    <p class="about-card-body">
                        Executed website revamp using WordPress, published
                        content, and assisted in event program coordination.
                    </p>
                </article>
            </div>
        </section>
    </div>
</BaseLayout>

<script is:inline>
    const skillTabs = Array.from(document.querySelectorAll(".about-skill-tab"));
    const skillPanels = Array.from(document.querySelectorAll(".about-cloud-panel"));

    skillTabs.forEach((tab) => {
        tab.addEventListener("click", () => {
            const target = tab.dataset.target;
            if (!target) return;

            skillTabs.forEach((btn) => {
                btn.classList.toggle("is-active", btn === tab);
                btn.setAttribute("aria-selected", btn === tab ? "true" : "false");
            });

            skillPanels.forEach((panel) => {
                const active = panel.dataset.panel === target;
                panel.classList.toggle("is-active", active);
                panel.hidden = !active;
            });
        });
    });
</script>
