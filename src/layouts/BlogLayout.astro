---
import BaseLayout from "./BaseLayout.astro";

export interface Props {
    title: string;
    description?: string;
    pubDate: Date;
    tags?: string[];
}

const { title, description, pubDate, tags = [] } = Astro.props;

const formattedDate = new Date(pubDate).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
});
---

<BaseLayout
    title={`${title} | Steve Rahardjo`}
    description={description}
    page="writing"
>
    <article class="container page blog-post">
        <header class="blog-header">
            <h1 class="page-title">{title}</h1>
            <div class="blog-meta">
                <time datetime={pubDate.toISOString()}>{formattedDate}</time>
                {
                    tags.length > 0 && (
                        <div class="blog-tags">
                            {tags.map((tag) => (
                                <span class="tag">{tag}</span>
                            ))}
                        </div>
                    )
                }
            </div>
        </header>

        <div class="progress-bar" id="progressBar"></div>

        <div class="blog-content">
            <slot />
        </div>

        <a href="/writing" class="back-link">← Back to Writing</a>
    </article>
</BaseLayout>

<style>
    .blog-header {
        margin-bottom: 2rem;
    }

    .blog-meta {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
        margin-top: 0.5rem;
    }

    .blog-meta time {
        font-size: 0.9rem;
        color: var(--muted);
    }

    .blog-tags {
        display: flex;
        gap: 0.4rem;
        flex-wrap: wrap;
    }

    .blog-content {
        font-family:
            "TiM",
            -apple-system,
            BlinkMacSystemFont,
            "Segoe UI",
            Roboto,
            Helvetica,
            Arial,
            sans-serif;
        font-size: 1rem;
        line-height: 1.8;
    }

    .blog-content :global(h1),
    .blog-content :global(h2),
    .blog-content :global(h3) {
        font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
        font-weight: 700;
        margin-top: 2rem;
        margin-bottom: 1rem;
    }

    .blog-content :global(h1) {
        font-size: 2rem;
    }

    .blog-content :global(h2) {
        font-size: 1.5rem;
    }

    .blog-content :global(h3) {
        font-size: 1.25rem;
    }

    .blog-content :global(p) {
        margin-bottom: 1.5rem;
    }

    .blog-content :global(ul),
    .blog-content :global(ol) {
        margin-bottom: 1.5rem;
        padding-left: 1.5rem;
    }

    .blog-content :global(li) {
        margin-bottom: 0.5rem;
    }

    .blog-content :global(code) {
        font-family: "SF Mono", Monaco, "Cascadia Code", monospace;
        font-size: 0.85em;
        background: var(--border);
        padding: 0.2em 0.4em;
        border-radius: 3px;
    }

    .blog-content :global(pre) {
        background: var(--border);
        padding: 1rem;
        border-radius: 4px;
        overflow-x: auto;
        margin-bottom: 1.5rem;
    }

    .blog-content :global(pre code) {
        background: none;
        padding: 0;
    }

    .blog-content :global(a) {
        color: var(--red);
        text-decoration: none;
    }

    .blog-content :global(a:hover) {
        text-decoration: underline;
    }

    .back-link {
        display: inline-block;
        margin-top: 3rem;
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--muted);
        text-decoration: none;
        transition: color 0.2s;
    }

    .back-link:hover {
        color: var(--text);
    }
</style>
