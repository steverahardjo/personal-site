---
import BaseLayout from "./BaseLayout.astro";

export interface Props { title: string; description?: string; pubDate: Date; tags?: string[]; }

const { title, description, pubDate, tags = [] } = Astro.props;
const date = new Date(pubDate).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
---

<BaseLayout title={`${title} | Steve Rahardjo`} description={description} page="writing">
  <article>
    <header class="mb-8">
      <h1 class="text-2xl md:text-3xl font-bold tracking-tight m-0">{title}</h1>
      <div class="flex items-center gap-3 mt-2 flex-wrap">
        <time class="text-xs text-[var(--muted-foreground)]" datetime={pubDate.toISOString()}>{date}</time>
        {tags.map(t => <span class="text-[10px] font-medium px-2 py-0.5 rounded border border-[var(--border)] bg-[var(--bg)] text-[var(--muted-foreground)]">{t}</span>)}
      </div>
    </header>
    <div class="text-sm leading-relaxed [&_h2]:text-lg [&_h2]:font-bold [&_h2]:mt-8 [&_h2]:mb-4 [&_h3]:text-base [&_h3]:font-semibold [&_h3]:mt-6 [&_h3]:mb-3 [&_p]:mb-4 [&_ul]:mb-4 [&_ol]:mb-4 [&_ul]:pl-5 [&_ol]:pl-5 [&_li]:mb-2 [&_code]:text-[11px] [&_code]:bg-[var(--border)] [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded [&_pre]:bg-[var(--bg)] [&_pre]:border [&_pre]:border-[var(--border)] [&_pre]:p-4 [&_pre]:rounded-xl [&_pre]:overflow-x-auto [&_pre]:mb-4 [&_pre_code]:bg-transparent [&_pre_code]:p-0 [&_a]:text-[var(--accent)] [&_a]:no-underline [&_a:hover]:underline">
      <slot />
    </div>
    <a href="/writing" class="inline-block mt-8 text-xs text-[var(--muted-foreground)] no-underline hover:text-[var(--text)] transition-colors">&larr; Back to Writing</a>
  </article>
</BaseLayout>

<script is:inline>
  document.querySelectorAll("pre").forEach(pre => {
    const wrap = document.createElement("div");
    wrap.className = "relative group";
    pre.parentNode.insertBefore(wrap, pre);
    wrap.appendChild(pre);

    const btn = document.createElement("button");
    btn.className = "absolute top-2 right-2 opacity-0 group-hover:opacity-100 transition-opacity duration-200 text-[10px] font-mono font-medium px-2 py-1 rounded border border-[var(--border)] bg-[var(--surface)] text-[var(--muted-foreground)] hover:text-[var(--accent)] cursor-pointer";
    btn.textContent = "copy";
    btn.setAttribute("aria-label", "Copy code");
    wrap.appendChild(btn);

    btn.addEventListener("click", async () => {
      const code = pre.querySelector("code") || pre;
      try {
        await navigator.clipboard.writeText(code.textContent || pre.textContent || "");
        btn.textContent = "copied!";
        setTimeout(() => { btn.textContent = "copy"; }, 1500);
      } catch { btn.textContent = "failed"; }
    });
  });
</script>
