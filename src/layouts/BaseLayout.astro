---
import JsonLd from '../components/JsonLd.astro';

export interface Props {
    title: string;
    description?: string;
    page?: string;
}

const { title, description, page } = Astro.props;

const siteUrl = 'https://sjrah.net';
const defaultDescription = 'Steve Jevon Rahardjo - Data Science graduate specializing in backend systems, AI/ML, and database optimization. Building scalable software solutions.';
const pageDescription = description || defaultDescription;

const ogImage = `${siteUrl}/og-image.png`;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={pageDescription} />
        <meta name="author" content="Steve Jevon Rahardjo" />
        <meta name="robots" content="index, follow" />
        
        <!-- Canonical URL -->
        <link rel="canonical" href={`${siteUrl}${Astro.url.pathname}`} />
        
        <!-- Open Graph / Facebook -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={`${siteUrl}${Astro.url.pathname}`} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={pageDescription} />
        <meta property="og:image" content={ogImage} />
        <meta property="og:site_name" content="Steve Jevon Rahardjo" />
        
        <!-- Twitter -->
        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={`${siteUrl}${Astro.url.pathname}`} />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={pageDescription} />
        <meta property="twitter:image" content={ogImage} />
        
        <title>{title}</title>
        <link
            rel="icon"
            href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>👨‍💻</text></svg>"
        />
        <link rel="stylesheet" href="/styles.css" />
        
        <!-- JSON-LD Structured Data -->
        <JsonLd 
            name="Steve Jevon Rahardjo"
            jobTitle="Software Engineer"
            email="steve.jevon.r@gmail.com"
            github="https://github.com/steverahardjo"
            linkedin="https://linkedin.com/in/steve-jevon-rahardjo"
        />
    </head>
    <body class={page === "writing" ? "writing-page" : ""}>
        <div class="theme-toggle" id="themeToggle">◐</div>

        <div class="blue-hue"></div>

        <header class="header">
            <nav class="nav">
                <a
                    href="/"
                    class={`nav-link ${page === "home" ? "active" : ""}`}
                    >Home</a
                >
                <a
                    href="/about"
                    class={`nav-link ${page === "about" ? "active" : ""}`}
                    >About</a
                >
                <a
                    href="/projects"
                    class={`nav-link ${page === "projects" ? "active" : ""}`}
                    >Projects</a
                >
                <a
                    href="/writing"
                    class={`nav-link ${page === "writing" ? "active" : ""}`}
                    >Writing</a
                >
            </nav>
        </header>

        <main>
            <slot />
        </main>

        <footer class="footer">
            <div class="footer-container">
                <div class="footer-social">
                    <a
                        href="https://github.com/steverahardjo"
                        class="footer-link"
                        target="_blank"
                        rel="noopener"
                        aria-label="GitHub"
                    >
                        <svg
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            class="footer-icon"
                        >
                            <path
                                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                            ></path>
                        </svg>
                    </a>
                    <a
                        href="https://linkedin.com/in/steve-jevon-rahardjo"
                        class="footer-link"
                        target="_blank"
                        rel="noopener"
                        aria-label="LinkedIn"
                    >
                        <svg
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            class="footer-icon"
                        >
                            <path
                                d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                            ></path>
                        </svg>
                    </a>
                    <a
                        href="mailto:steve.jevon.r@gmail.com"
                        class="footer-link"
                        aria-label="Email"
                    >
                        <svg
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            class="footer-icon"
                        >
                            <path
                                d="M0 3v18h24v-18h-24zm21.518 2l-9.518 7.713-9.518-7.713h19.036zm-19.518 14v-11.817l10 8.104 10-8.104v11.817h-20z"
                            ></path>
                        </svg>
                    </a>
                </div>
            </div>
        </footer>

        <script src="/script.js" is:inline></script>
    </body>
</html>
