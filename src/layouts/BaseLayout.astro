---
import JsonLd from "../components/JsonLd.astro";
import "../styles/tailwind.css";
import "../styles/style.css";

export interface Props {
  title: string;
  description?: string;
  page?: string;
}

const { title, description, page = "" } = Astro.props;
const currentYear = new Date().getFullYear();
const siteUrl = "https://sjrah.net";
const pageDescription = description || "Steve Jevon Rahardjo - building software.";
const ogImage = `${siteUrl}/og-image.png`;

const navItems = [
  { id: "home", href: "/", label: "Home", sub: "Index", icon: "M12 3L3 8.5V21h7v-7h4v7h7V8.5L12 3z" },
  { id: "about", href: "/about", label: "About", sub: "Bio", icon: "M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" },
  { id: "projects", href: "/projects", label: "Projects", sub: "Works", icon: "M20 6h-8l-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm0 12H4V8h16v10z" },
  { id: "writing", href: "/writing", label: "Writing", sub: "Blog", icon: "M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm4 18H6V4h7v5h5v11z" },
];
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={`${siteUrl}${Astro.url.pathname}`} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${siteUrl}${Astro.url.pathname}`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={pageDescription} />
    <meta property="twitter:image" content={ogImage} />
    <title>{title}</title>
    <link rel="icon" href="/favicon-v2.svg" type="image/svg+xml" />
    <JsonLd
      name="Steve Jevon Rahardjo"
      jobTitle="Software Engineer"
      email="steve.jevon.r@gmail.com"
      github="https://github.com/steverahardjo"
      linkedin="https://linkedin.com/in/steve-jevon-rahardjo"
    />
  </head>
  <body class="flex items-center justify-center min-h-[100dvh] p-2 md:p-6 bg-[var(--bg)]">
    <div class="flex w-full max-w-5xl flex-col md:flex-row border border-[var(--border)] md:rounded-3xl overflow-hidden shadow-sm bg-[var(--surface)]">

      <!-- Sidebar -->
      <aside class="relative flex w-full flex-col border-b md:border-b-0 md:w-[35%] md:border-r border-[var(--border)] p-6 md:p-10 sidebar-scroll md:max-h-[calc(100dvh-3rem)] md:overflow-y-auto overflow-hidden"
        style="background: color-mix(in srgb, var(--surface) 97%, var(--accent));">
        <!-- Dot-matrix texture overlay -->
        <div class="absolute inset-0 pointer-events-none opacity-[0.03]"
          style="background-image: radial-gradient(circle, var(--accent) 0.8px, transparent 0.8px); background-size: 12px 12px;"></div>

        <div class="relative z-10 flex flex-col h-full">
          <!-- Logo + Glyph Toggle Row -->
          <div class="flex items-center justify-between mb-6 md:mb-10">
            <img src="/favicon-v2.svg" alt="sjrah" class="w-10 h-10 md:w-11 md:h-11" />
            <button id="themeToggle" type="button" aria-label="Toggle theme"
              class="relative w-11 h-6 rounded-full border border-[var(--border)] bg-transparent cursor-pointer transition-all duration-300 hover:border-[var(--accent)]/50 flex items-center px-0.5"
            >
              <span id="themeIcon" class="w-4 h-4 rounded-full bg-[var(--text)] transition-transform duration-300 flex items-center justify-center">
                <img src="/owl.svg" alt="" class="w-3 h-3" style="filter: invert(1) brightness(10);" />
              </span>
            </button>
          </div>

          <!-- Name + Tagline -->
          <div class="mb-6 md:mb-10">
            <h1 class="text-sm md:text-base font-bold tracking-tight m-0">Steve Jevon Rahardjo</h1>
            <p class="mt-2 hidden md:block text-[11px] text-[var(--muted-foreground)] leading-relaxed">CS graduate building backend systems, AI tools, and the occasional rabbit hole.</p>
          </div>

          <!-- Navigation with glyph icons -->
          <nav class="flex flex-wrap gap-1.5 md:flex-col md:gap-0.5">
            {navItems.map(({ id, href, label, sub, icon }) => (
              <a href={href}
                class={`flex items-center gap-3 w-full px-3 py-2.5 rounded-xl text-sm font-medium no-underline transition-all duration-200 group ${
                  page === id
                    ? "text-[var(--accent)] bg-[var(--accent)]/8"
                    : "text-[var(--muted-foreground)] hover:text-[var(--text)] hover:bg-[var(--border)]/30"
                }`}
              >
                <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d={icon} />
                </svg>
                <div class="flex flex-col leading-tight">
                  <span class="text-sm font-medium">{label}</span>
                  <span class="text-[9px] tracking-[0.15em] uppercase opacity-50">{sub}</span>
                </div>
                <svg class="w-3.5 h-3.5 ml-auto hidden md:block opacity-0 -translate-x-2 transition-all duration-200 group-hover:opacity-100 group-hover:translate-x-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            ))}
          </nav>

          <!-- Social + Footer -->
          <div class="mt-auto pt-8 md:pt-14">
            <div class="flex items-center gap-3 text-[var(--muted-foreground)]">
              <a href="https://github.com/steverahardjo" target="_blank" rel="noopener" aria-label="GitHub" class="hover:text-[var(--accent)] transition-colors">
                <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              </a>
              <a href="https://linkedin.com/in/steve-jevon-rahardjo" target="_blank" rel="noopener" aria-label="LinkedIn" class="hover:text-[var(--accent)] transition-colors">
                <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
              </a>
              <a href="mailto:steve.jevon.r@gmail.com" aria-label="Email" class="hover:text-[var(--accent)] transition-colors">
                <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M0 3v18h24v-18h-24zm21.518 2l-9.518 7.713-9.518-7.713h19.036zm-19.518 14v-11.817l10 8.104 10-8.104v11.817h-20z"/></svg>
              </a>
            </div>
            <p class="mt-6 text-[9px] text-[var(--muted-foreground)] tracking-wider">&copy; {currentYear} SJR.</p>
          </div>
        </div>
      </aside>

      <!-- Content -->
      <main class="flex-1 bg-[var(--surface)] content-scroll md:max-h-[calc(100dvh-3rem)] md:overflow-y-auto">
        <div class="max-w-2xl mx-auto p-8 md:p-16">
          <slot />
        </div>
      </main>

    </div>
    <script src="/script.js" defer></script>
  </body>
</html>
